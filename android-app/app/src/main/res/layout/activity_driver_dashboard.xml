<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_welcome_driver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Abdullah Al-Kandari"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tv_driver_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="abdullah@logistics.kw"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <Button
                android:id="@+id/btn_logout_driver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/border_color"
                android:text="EXIT"
                android:textColor="@color/danger"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Dynamic Shift Attendance Punch Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NFC SHIFT CLOCK ACTIVE"
                android:textColor="@color/danger"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <!-- Highlight Status Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/dark_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/v_status_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginRight="12dp" />

                <TextView
                    android:id="@+id/tv_attendance_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS: OFFLOCK (PUNCH-IN VACANT)"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Timestamps Details -->
            <TextView
                android:id="@+id/tv_punch_in_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PUNCH-IN TIME: -- : --"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_punch_out_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PUNCH-OUT TIME: -- : --"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <!-- Tag Detection visual target -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/dash_border_accent"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_nfc_hud"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP SMARTCARD DEVICE ANTENNA"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active RFID Foreground Receiver Enabled"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Today's Vehicle Report & Metrics Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY'S VEHICLE REPORT &amp; METRICS"
                android:textColor="@color/danger"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <!-- Start Odometer Metrics -->
            <TextView
                android:id="@+id/tv_start_odometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start: -- km"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- End Odometer Metrics -->
            <TextView
                android:id="@+id/tv_end_odometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End: -- km"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Duration Metrics -->
            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duration: --"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Fuel Budget Consumption Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FUEL BUDGET CONSUMPTION REPORT"
                android:textColor="@color/danger"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <!-- Allocated Budget -->
            <TextView
                android:id="@+id/tv_allocated_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allocated Budget: -- KD"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Remaining Budget -->
            <TextView
                android:id="@+id/tv_remaining_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remaining Budget: -- KD"
                android:textColor="@color/success"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="8dp" />

            <!-- Additional Spent -->
            <TextView
                android:id="@+id/tv_additional_spent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Additional Spent: -- KD"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Toyota Fortuner Maintenance log panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOYOTA FORTUNER MAINTENANCE LOG"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:layout_marginBottom="16dp" />

            <!-- Event category selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAINTENANCE CATEGORY"
                android:textColor="@color/text_secondary"
                android:textSize="9dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spn_category"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/dark_background"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <!-- Mileage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT VEHICLE ODOMETER (KM)"
                android:textColor="@color/text_secondary"
                android:textSize="9dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_maint_odo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/dark_background"
                android:hint="e.g. 142050"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Cost -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL COMPONENT COST (KWD)"
                android:textColor="@color/text_secondary"
                android:textSize="9dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_maint_cost"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/dark_background"
                android:hint="e.g. 45.000"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Additional Amount Checkbox -->
            <CheckBox
                android:id="@+id/cb_additional_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARK AS ADDITIONAL AMOUNT (EXCLUDED FROM BASE BUDGET)"
                android:textColor="@color/white"
                android:buttonTint="@color/danger"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <!-- Spare parts part codes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPARE PARTS / FILTERS CODES (OEM TOYOTA)"
                android:textColor="@color/text_secondary"
                android:textSize="9dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_part_codes"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/dark_background"
                android:hint="e.g. 17801-0L040 Air Filter"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Save maintenance log button -->
            <Button
                android:id="@+id/btn_save_maint"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="@color/danger"
                android:text="SUBMIT SERVICE LOG"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
