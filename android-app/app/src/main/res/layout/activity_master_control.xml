<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MASTER CONTROL PANEL"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MULTI-TENANT ROUTER &amp; NEW COMPANY CREATION"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp" />

        <!-- Add Company Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CREATE NEW TENANT / COMPANY"
                android:textColor="@color/danger"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPANY NAME"
                android:textColor="@color/text_secondary"
                android:textSize="9dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_company_name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/dark_background"
                android:hint="e.g. Al-Hamra Logistics"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPANY ID (ALPHANUMERIC)"
                android:textColor="@color/text_secondary"
                android:textSize="9dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_company_id_input"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/dark_background"
                android:hint="e.g. COM_ALHAMRA"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Sub Section: Admin User Account Init -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPANY ADMIN DEFAULT CREDENTIALS"
                android:textColor="@color/text_secondary"
                android:textSize="8sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_admin_email"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@color/dark_background"
                android:hint="Admin Email (e.g. admin@alhamra.com)"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="textEmailAddress"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_admin_password"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@color/dark_background"
                android:hint="Admin Password (e.g. 1234)"
                android:textColorHint="#404040"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btn_create_company"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="@color/danger"
                android:text="INITIALIZE COMPANY PROFILE"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black" />

        </LinearLayout>

        <!-- Company Directory List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE SYSTEM REGISTERED TENANTS"
                android:textColor="@color/white"
				android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Scrollable List of companies -->
            <LinearLayout
                android:id="@+id/layout_companies_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_back_to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/border_color"
            android:text="GO BACK TO LOGIN screen"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_gravity="center" />

    </LinearLayout>
</ScrollView>
