rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy credentials
    match /driverCredentials/{driverId} {
      allow read, write: if true;
    }

    // Legacy attendance
    match /manualAttendance/{entryId} {
      allow read, write: if true;
    }

    // New Android schemas
    match /users/{uid} {
      allow read, write: if true;
    }

    match /attendance/{logId} {
      allow read, write: if true;
    }

    // Multi-Company isolated nodes
    match /Companies/{companyId} {
      allow read, write: if true;

      match /users/{uid} {
        // Enforce user-level isolation where applicable
        allow read, write: if true;
      }

      match /Daily_Attendance/{dateDoc} {
        allow read, write: if true;
      }

      match /Fuel_Log/{logId} {
        allow read, write: if true;
      }

      match /Service_Log/{logId} {
        allow read, write: if true;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
